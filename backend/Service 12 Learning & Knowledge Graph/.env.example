# ─────────────────────────────────────────────
# Environment Variables for Knowledge Graph Service
# Copy to .env and fill in values
# ─────────────────────────────────────────────

# --- Neptune ---
NEPTUNE_ENDPOINT=your-neptune-cluster.cluster-xxxx.us-east-1.neptune.amazonaws.com
NEPTUNE_PORT=8182
NEPTUNE_USE_IAM=true

# --- DynamoDB ---
AWS_REGION=us-east-1
DYNAMODB_TABLE_RETURN_EVENTS=CircularOS-ReturnEvents
DYNAMODB_TABLE_PRODUCT_TWINS=CircularOS-ProductTwinReferences
DYNAMODB_TABLE_FRAUD_SCORES=CircularOS-FraudScores
DYNAMODB_TABLE_RECOVERY_DECISIONS=CircularOS-RecoveryDecisions

# --- EventBridge ---
EVENTBRIDGE_BUS_NAME=circular-intelligence-bus

# --- S3 ---
S3_BUCKET_GRAPH_EXPORTS=circular-os-graph-exports

# --- Service ---
ENVIRONMENT=development
LOG_LEVEL=INFO
