{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProductCreateRequest",
  "type": "object",
  "required": [
    "product_id",
    "title",
    "category",
    "brand",
    "price",
    "seller_id"
  ],
  "properties": {
    "product_id": { "type": "string" },
    "title": { "type": "string" },
    "category": { "type": "string" },
    "brand": { "type": "string" },
    "price": { "type": "number" },
    "seller_id": { "type": "string" },
    "warehouse_id": { "type": ["string", "null"] }
  }
}
