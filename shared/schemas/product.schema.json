{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Product Entity",
  "type": "object",
  "required": [
    "productId",
    "title",
    "category",
    "price",
    "sellerId"
  ],
  "properties": {
    "productId": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "price": {
      "type": "number"
    },
    "sellerId": {
      "type": "string"
    }
  }
}
