{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RecoveryActionCreateRequest",
  "type": "object",
  "required": [
    "action_id",
    "return_id",
    "action_type"
  ],
  "properties": {
    "action_id": { "type": "string" },
    "return_id": { "type": "string" },
    "action_type": { "type": "string" },
    "estimated_value_recovered": { "type": "number", "default": 0.0 },
    "cost_incurred": { "type": "number", "default": 0.0 },
    "confidence": { "type": "number", "default": 1.0 }
  }
}
