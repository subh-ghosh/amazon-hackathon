{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RootCauseDiscovered",
  "type": "object",
  "required": [
    "eventType",
    "returnId",
    "productId",
    "rootCause",
    "confidence",
    "timestamp"
  ],
  "properties": {
    "eventType": {
      "type": "string"
    },
    "returnId": {
      "type": "string"
    },
    "productId": {
      "type": "string"
    },
    "rootCause": {
      "type": "string"
    },
    "confidence": {
      "type": "number"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}
