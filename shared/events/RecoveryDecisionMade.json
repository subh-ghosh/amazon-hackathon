{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RecoveryDecisionMade",
  "type": "object",
  "required": [
    "eventType",
    "returnId",
    "action",
    "estimatedRecovery",
    "timestamp"
  ],
  "properties": {
    "eventType": {
      "type": "string"
    },
    "returnId": {
      "type": "string"
    },
    "action": {
      "enum": ["RESTOCK", "LIQUIDATE", "REFURBISH", "RECYCLE", "DESTROY"]
    },
    "estimatedRecovery": {
      "type": "number"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}
